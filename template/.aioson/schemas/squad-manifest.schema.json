{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiosforge.dev/schemas/squad-manifest.schema.json",
  "title": "AIOSON Squad Manifest",
  "description": "Schema para squad.manifest.json",
  "type": "object",
  "required": ["schemaVersion", "slug", "name", "mode", "mission", "goal"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Versão do schema (semver)"
    },
    "packageVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 50,
      "description": "Identificador kebab-case do squad"
    },
    "name": {
      "type": "string",
      "maxLength": 100
    },
    "mode": {
      "type": "string",
      "enum": ["content", "software", "research", "mixed"],
      "description": "Tipo principal do squad"
    },
    "mission": { "type": "string", "maxLength": 500 },
    "goal": { "type": "string", "maxLength": 500 },
    "visibility": {
      "type": "string",
      "enum": ["private", "public"],
      "default": "private"
    },
    "locale_scope": {
      "type": "string",
      "description": "Universal or locale-specific scope for agent prompt files",
      "pattern": "^(universal|[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*)$"
    },
    "locale_rationale": {
      "type": "string",
      "description": "Why the squad is locale-specific when locale_scope is not universal"
    },
    "domainClassification": {
      "type": "object",
      "description": "Classification of the squad domain for research and safety routing",
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["tier-1-regulated", "tier-2-specialized", "tier-3-common"]
        },
        "rationale": { "type": "string" },
        "regulations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "investigationPolicy": {
          "type": "string",
          "enum": ["required", "recommended", "optional"]
        }
      }
    },
    "ephemeral": {
      "type": "boolean",
      "default": false,
      "description": "Temporary squad — created ad-hoc for a one-off task, no persistence. Auto-cleaned after session ends."
    },
    "ttl": {
      "type": "string",
      "description": "Time-to-live for ephemeral squads (e.g. '24h', '7d'). After TTL, squad files are eligible for cleanup."
    },
    "aiosLiteCompatibility": { "type": "string" },
    "sourceDocs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Project artifacts consumed during squad design"
    },
    "analysis": {
      "type": "object",
      "description": "Domain decomposition from sourceDocs (design Passo 2.5) — the roster was derived from this; read by squad-analyze and squad-validate",
      "properties": {
        "entities": { "type": "array", "items": { "type": "string" } },
        "workflows": { "type": "array", "items": { "type": "string" } },
        "integrations": { "type": "array", "items": { "type": "string" } },
        "stakeholders": { "type": "array", "items": { "type": "string" } }
      }
    },
    "investigation": {
      "type": "object",
      "description": "Reference to a persisted @orache investigation report",
      "properties": {
        "slug": { "type": "string" },
        "path": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "dimensionsCovered": { "type": "integer", "minimum": 0, "maximum": 7 },
        "date": { "type": "string", "format": "date" }
      }
    },
    "storagePolicy": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "enum": ["sqlite", "file"] },
        "artifacts": { "type": "string" },
        "exports": {
          "type": "object",
          "properties": {
            "html": { "type": "boolean" },
            "markdown": { "type": "boolean" },
            "json": { "type": "boolean" }
          }
        }
      }
    },
    "package": {
      "type": "object",
      "properties": {
        "rootDir": { "type": "string" },
        "agentsDir": { "type": "string" },
        "workersDir": { "type": "string", "description": "Directory for deterministic worker scripts (no LLM)" },
        "workflowsDir": { "type": "string", "description": "Directory for workflow .md files with phases and handoffs" },
        "checklistsDir": { "type": "string", "description": "Directory for quality checklist .md files" },
        "skillsDir": { "type": "string" },
        "templatesDir": { "type": "string" },
        "docsDir": { "type": "string" }
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "outputsDir": { "type": "string" },
        "logsDir": { "type": "string" },
        "mediaDir": { "type": "string" },
        "reviewPolicy": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "executors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "role"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["worker", "agent", "clone", "assistant", "human-gate", "research", "reviewer", "skill"],
            "default": "agent",
            "description": "Executor type: worker (deterministic script, no LLM), agent (LLM with defined role), clone (cognitive replica of real person), assistant (domain specialist with behavioral profile), human-gate (human approval checkpoint), research (web research with cache, no LLM), reviewer (cross-AI review synthesis), skill (external Agent Skills Standard skill)"
          },
          "role": { "type": "string" },
          "file": { "type": "string" },
          "traces": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Workflows/entities (from analysis) this executor owns — from the design decomposition"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "How well the sources justify this executor's role (design decomposition)"
          },
          "deterministic": {
            "type": "boolean",
            "description": "Whether the executor always produces the same output for the same input"
          },
          "usesLLM": {
            "type": "boolean",
            "description": "Whether the executor uses an LLM (false = zero LLM cost)"
          },
          "runtime": {
            "type": "string",
            "enum": ["python", "bash", "node", "other"],
            "description": "Runtime for worker executors"
          },
          "entrypoint": {
            "type": "string",
            "description": "Script path for worker executors"
          },
          "skill": {
            "type": "string",
            "description": "Agent Skills Standard skill identifier (for type: 'skill'). E.g. '@anthropic/code-review'"
          },
          "source": {
            "type": "string",
            "description": "Skill source path or package. E.g. 'npm:@org/skill', './skills/my-skill/'"
          },
          "domain": {
            "type": "string",
            "description": "Specialized domain for assistant executors"
          },
          "behavioralProfile": {
            "type": "string",
            "enum": [
              "dominant-driver",
              "influential-expressive",
              "steady-amiable",
              "compliant-analytical",
              "dominant-influential",
              "influential-steady",
              "steady-compliant",
              "compliant-dominant"
            ],
            "description": "DISC-based behavioral profile for assistant executors. Primary-secondary pattern: D=results-driven, I=people-oriented, S=stability-focused, C=precision-oriented"
          },
          "genomeSource": {
            "type": "string",
            "description": "Path to genome file for clone executors"
          },
          "fidelityScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Cognitive fidelity score for clone executors (0-1)"
          },
          "personReal": {
            "type": "boolean",
            "description": "Whether the clone is based on a real person"
          },
          "trigger": {
            "type": "string",
            "description": "Condition that activates a human-gate executor"
          },
          "escalation": {
            "type": "object",
            "description": "Graduated escalation rules for human-gate executors",
            "properties": {
              "rules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "condition": { "type": "string" },
                    "action": {
                      "type": "string",
                      "enum": ["auto", "consult", "approve", "block"]
                    },
                    "consultAgent": { "type": "string" },
                    "notifyVia": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "modelTier": {
            "type": "string",
            "enum": ["powerful", "balanced", "fast", "none"],
            "default": "balanced",
            "description": "Model tier for this executor. powerful: best model (Opus/o3). balanced: good model (Sonnet/GPT-4o). fast: cheap model (Haiku/Flash). none: no LLM (workers)."
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["slug", "title", "order"],
              "properties": {
                "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "title": { "type": "string" },
                "order": { "type": "integer", "minimum": 1 },
                "file": { "type": "string", "description": "Path to the task .md file" },
                "input": { "type": "string", "description": "What this task receives" },
                "output": { "type": "string", "description": "What this task produces" },
                "review_loop": {
                  "type": "boolean",
                  "default": false,
                  "description": "Enable evaluator-optimizer loop: dev implements, qa evaluates, repeat up to max_review_iterations"
                },
                "review_criteria": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Criteria the evaluator uses to PASS/FAIL the output (used with review_loop: true)"
                },
                "max_review_iterations": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5,
                  "default": 3,
                  "description": "Maximum dev→qa iterations before escalating to human (used with review_loop: true)"
                },
                "voting": {
                  "type": "object",
                  "description": "Sampling-and-Voting: run N parallel instances and reach consensus. Best for critical decisions.",
                  "properties": {
                    "instances": {
                      "type": "integer",
                      "minimum": 2,
                      "maximum": 10,
                      "default": 3,
                      "description": "Number of parallel instances to spawn"
                    },
                    "threshold": {
                      "type": "number",
                      "minimum": 0.5,
                      "maximum": 1,
                      "default": 0.66,
                      "description": "Minimum consensus fraction to accept result (0.66 = 66%)"
                    },
                    "on_no_consensus": {
                      "type": "string",
                      "enum": ["escalate", "use_majority", "fail"],
                      "default": "escalate",
                      "description": "What to do when consensus < threshold"
                    }
                  }
                }
              }
            },
            "description": "Granular tasks within this executor, executed in order"
          },
          "research": {
            "type": "object",
            "description": "Configuration for research executor type (type: 'research')",
            "properties": {
              "topic": { "type": "string", "description": "Cache key / topic slug (e.g. 'youtube-shorts-2026')" },
              "urls": {
                "type": "array",
                "items": { "type": "string" },
                "description": "URLs to scrape for this research topic"
              },
              "cache_hours": { "type": "integer", "default": 168, "description": "Cache TTL in hours (default 168 = 7 days)" },
              "cache_dir": { "type": "string", "default": "researchs/", "description": "Base directory for research cache" },
              "max_sources": { "type": "integer", "default": 5, "description": "Maximum number of URLs to scrape" }
            }
          },
          "cross_ai": {
            "type": "boolean",
            "description": "If true (for reviewer type), send to multiple AI CLIs and synthesize responses"
          },
          "review": {
            "type": "object",
            "description": "Configuration for reviewer executor type",
            "properties": {
              "detect_clis": {
                "type": "array",
                "items": { "type": "string", "enum": ["claude", "gemini", "codex"] }
              },
              "exclude_current": { "type": "boolean", "default": true },
              "synthesize_to": { "type": "string", "description": "Output path for REVIEWS.md" }
            }
          },
          "formats": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Format slugs from the format catalog that this executor uses"
          },
          "skills": { "type": "array", "items": { "type": "string" } },
          "genomes": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["slug"],
                  "properties": {
                    "slug": { "type": "string" },
                    "type": { "type": "string" },
                    "mode": { "type": "string" },
                    "source": { "type": "string" },
                    "priority": { "type": "integer" },
                    "version": { "type": "string" },
                    "evidenceMode": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "mcps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug"],
        "properties": {
          "slug": { "type": "string" },
          "required": { "type": "boolean" },
          "purpose": { "type": "string" }
        }
      }
    },
    "subagents": {
      "type": "object",
      "properties": {
        "allowed": { "type": "boolean" },
        "when": { "type": "array", "items": { "type": "string" } }
      }
    },
    "genomes": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "object" }
            ]
          }
        },
        {
          "type": "object",
          "properties": {
            "squad": {
              "type": "array",
              "items": {
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "required": ["slug"],
                    "properties": {
                      "slug": { "type": "string" },
                      "type": { "type": "string" },
                      "mode": { "type": "string" },
                      "source": { "type": "string" },
                      "priority": { "type": "integer" },
                      "version": { "type": "string" },
                      "evidenceMode": { "type": "string" },
                      "notes": { "type": "string" }
                    }
                  }
                ]
              }
            },
            "executors": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "object",
                      "required": ["slug"],
                      "properties": {
                        "slug": { "type": "string" },
                        "type": { "type": "string" },
                        "mode": { "type": "string" },
                        "source": { "type": "string" },
                        "priority": { "type": "integer" },
                        "version": { "type": "string" },
                        "evidenceMode": { "type": "string" },
                        "notes": { "type": "string" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "checklists": {
      "type": "array",
      "description": "Quality checklists for post-execution validation",
      "items": {
        "type": "object",
        "required": ["slug", "file"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "file": { "type": "string", "description": "Path to the checklist .md file" },
          "scope": {
            "type": "string",
            "enum": ["squad", "workflow", "phase", "executor"],
            "default": "squad",
            "description": "When this checklist applies"
          },
          "appliesTo": {
            "type": "string",
            "description": "Slug of the workflow, phase, or executor this checklist validates"
          }
        }
      }
    },
    "workflows": {
      "type": "array",
      "description": "Pipelines with phases, executors, handoffs, and execution modes",
      "items": {
        "type": "object",
        "required": ["slug", "title"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "trigger": { "type": "string", "description": "Condition or user action that starts this workflow" },
          "executionMode": {
            "type": "string",
            "enum": ["sequential", "parallel", "mixed"],
            "default": "sequential",
            "description": "How phases run: sequential (each waits for previous), parallel (all at once), mixed (phases declare their own mode)"
          },
          "estimatedDuration": { "type": "string", "description": "Human-readable estimate, e.g. '30-60min'" },
          "file": { "type": "string", "description": "Path to the workflow .md file" },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "executor"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "title": { "type": "string" },
                "executor": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "array", "items": { "type": "string" } }
                  ],
                  "description": "Executor slug(s) responsible for this phase"
                },
                "executorType": {
                  "type": "string",
                  "enum": ["worker", "agent", "clone", "assistant", "human-gate"]
                },
                "dependsOn": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Phase IDs that must complete before this phase starts"
                },
                "parallel": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this phase can run in parallel with siblings"
                },
                "input": { "type": "string", "description": "Expected input description or source" },
                "output": { "type": "string", "description": "Expected output artifact or description" },
                "humanGate": {
                  "type": "object",
                  "description": "Optional human approval checkpoint within this phase",
                  "properties": {
                    "condition": { "type": "string", "description": "Expression that triggers the gate" },
                    "action": {
                      "type": "string",
                      "enum": ["auto", "consult", "approve", "block"]
                    },
                    "consultAgent": { "type": "string" },
                    "notifyVia": { "type": "array", "items": { "type": "string" } },
                    "reason": { "type": "string" }
                  }
                },
                "checklist": { "type": "string", "description": "Path to quality checklist for this phase" },
                "review": {
                  "type": "object",
                  "properties": {
                    "reviewer": {
                      "type": "string",
                      "description": "Executor slug that reviews this phase's output"
                    },
                    "criteria": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "What the reviewer checks"
                    },
                    "onReject": {
                      "type": "string",
                      "description": "Phase ID to return to on rejection"
                    },
                    "maxRetries": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 5,
                      "default": 2,
                      "description": "Max rejection cycles before escalation"
                    },
                    "retryStrategy": {
                      "type": "string",
                      "enum": ["feedback", "fresh", "alternative"],
                      "default": "feedback",
                      "description": "feedback: send rejection reason back. fresh: restart from scratch. alternative: ask a different executor."
                    },
                    "escalateOnMaxRetries": {
                      "type": "string",
                      "enum": ["human", "skip", "fail"],
                      "default": "human",
                      "description": "What to do when maxRetries exceeded"
                    }
                  }
                },
                "vetoConditions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["condition", "action"],
                    "properties": {
                      "condition": {
                        "type": "string",
                        "description": "Natural language condition to check"
                      },
                      "action": {
                        "type": "string",
                        "enum": ["reject", "block", "warn"],
                        "description": "reject: auto-retry. block: stop pipeline. warn: continue with warning."
                      },
                      "message": {
                        "type": "string",
                        "description": "Message to show when condition is triggered"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "contextMonitor": {
      "type": "object",
      "description": "Context window monitoring configuration (Fase 1 — PRD 19.2 §3.1)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable context window monitoring for this squad"
        },
        "windowSize": {
          "type": "integer",
          "minimum": 1000,
          "description": "Override context window size in tokens (default: inferred from model tier)"
        },
        "thresholds": {
          "type": "object",
          "description": "Warning level thresholds as ratios (0–1)",
          "properties": {
            "warning":  { "type": "number", "minimum": 0, "maximum": 1, "default": 0.85 },
            "critical": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.95 }
          }
        },
        "notify": {
          "type": "object",
          "description": "Which events trigger notifications",
          "properties": {
            "contextWarning":  { "type": "boolean", "default": true,  "description": "Notify at warning threshold (default 85%)" },
            "contextCritical": { "type": "boolean", "default": true,  "description": "Notify at critical threshold (default 95%)" }
          }
        }
      }
    },
    "isolation": {
      "type": "object",
      "description": "Execution isolation strategy for agent branches (Fase 2 — PRD 19.2 §3.5)",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["worktree", "branch-only", "shared"],
          "default": "shared",
          "description": "worktree: separate git worktree per agent. branch-only: create branch but no worktree. shared: no isolation."
        },
        "branchPrefix": {
          "type": "string",
          "default": "aioson",
          "description": "Prefix for auto-created branches: {prefix}/{squadSlug}/{agentSlug}"
        },
        "autoMerge": {
          "type": "boolean",
          "default": false,
          "description": "Automatically fast-forward merge when agent task completes"
        },
        "cleanupOnComplete": {
          "type": "boolean",
          "default": true,
          "description": "Remove worktree/branch after successful merge"
        }
      }
    },
    "recovery": {
      "type": "object",
      "description": "Context recovery configuration after a compact event (Fase 3 — PRD 19.2 §3.6)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic recovery-context.md generation"
        },
        "autoInject": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inject recovery-context.md when a compact is detected (>30% drop in context)"
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 500,
          "maximum": 4000,
          "default": 2000,
          "description": "Maximum token budget for the generated recovery-context.md"
        },
        "refreshOn": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["task_completed", "decision_made", "handoff"]
          },
          "default": ["task_completed", "decision_made", "handoff"],
          "description": "Runtime event types that trigger an automatic recovery context refresh"
        }
      }
    },
    "contentBlueprints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "contentType", "layoutType"],
        "properties": {
          "slug": { "type": "string" },
          "contentType": { "type": "string" },
          "layoutType": {
            "type": "string",
            "enum": ["document", "tabs", "accordion", "stack", "mixed"]
          },
          "description": { "type": "string" },
          "sections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key", "label"],
              "properties": {
                "key": { "type": "string" },
                "label": { "type": "string" },
                "blockTypes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "outputStrategy": {
    "type": "object",
    "description": "How the squad routes, stores and delivers its outputs",
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["files", "sqlite", "hybrid"],
        "default": "hybrid",
        "description": "Primary output strategy: files (physical output only), sqlite (database only), hybrid (both)"
      },
      "fileOutput": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "dir": { "type": "string", "description": "Output directory path" },
          "formats": {
            "type": "array",
            "items": { "type": "string", "enum": ["html", "md", "json", "pdf", "csv"] },
            "description": "Enabled export formats"
          }
        }
      },
      "dataOutput": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "storage": { "type": "string", "enum": ["sqlite"], "default": "sqlite" },
          "table": { "type": "string", "default": "content_items" },
          "contentItems": { "type": "boolean", "default": true, "description": "Use the content_items model for structured data" }
        }
      },
      "delivery": {
        "type": "object",
        "properties": {
          "webhooks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["slug", "trigger"],
              "properties": {
                "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "url": { "type": "string", "description": "Webhook URL or {{ENV:VAR}} placeholder" },
                "trigger": {
                  "type": "string",
                  "enum": ["on-publish", "on-create", "manual"],
                  "default": "on-publish",
                  "description": "When to fire the webhook"
                },
                "format": {
                  "type": "string",
                  "enum": ["json", "form-data"],
                  "default": "json"
                },
                "headers": {
                  "type": "object",
                  "additionalProperties": { "type": "string" },
                  "description": "Custom headers (supports {{ENV:VAR}} placeholders)"
                },
                "worker": { "type": "string", "description": "Path to delivery worker script" }
              }
            }
          },
          "cloudPublish": { "type": "boolean", "default": false, "description": "Publish to aioson.com cloud" },
          "autoPublish": { "type": "boolean", "default": false, "description": "Auto-publish on content creation (opt-in)" }
        }
      }
    }
  },
  "ports": {
    "type": "object",
    "description": "Declaração de inputs e outputs para conexão inter-squad",
    "properties": {
      "inputs": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["key"],
          "properties": {
            "key": { "type": "string", "pattern": "^[a-z0-9-]+$" },
            "dataType": { "type": "string", "enum": ["text", "json", "file", "file-list", "any"], "default": "any" },
            "description": { "type": "string" },
            "required": { "type": "boolean", "default": false }
          }
        }
      },
      "outputs": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["key"],
          "properties": {
            "key": { "type": "string", "pattern": "^[a-z0-9-]+$" },
            "dataType": { "type": "string", "enum": ["text", "json", "file", "file-list", "any"], "default": "any" },
            "description": { "type": "string" },
            "contentBlueprintSlug": { "type": "string" }
          }
        }
      }
    }
  },
  "depends_on": {
    "type": "array",
    "description": "Inter-squad dependencies: this squad will consume published events from these squads before starting a run",
    "items": {
      "type": "object",
      "required": ["squad", "event"],
      "properties": {
        "squad": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Slug of the squad whose events this squad depends on"
        },
        "event": {
          "type": "string",
          "description": "Event pattern to subscribe to (e.g. 'episode.created', 'review.*', '*')"
        },
        "input_mapping": {
          "type": "object",
          "description": "Maps event payload fields to task context fields",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  },
  "hooks": {
    "type": "object",
    "description": "Hook scripts that gate squad execution (exit 0=allow, exit 2=deny)",
    "properties": {
      "pre_run": {
        "type": "string",
        "description": "Shell command to run before squad:autorun starts. Exit code 2 aborts the run."
      }
    }
  },
  "subscriptions": {
    "type": "array",
    "description": "Event patterns this squad subscribes to (consumed at the start of each autorun). Short form of depends_on[*].event.",
    "items": { "type": "string" }
  },
  "additionalProperties": true
}
