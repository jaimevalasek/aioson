{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiosforge.dev/schemas/squad-blueprint.schema.json",
  "title": "AIOSON Squad Blueprint",
  "description": "Schema para blueprints intermediários de design de squad",
  "type": "object",
  "required": ["id", "slug", "name", "problem", "goal", "mode"],
  "properties": {
    "id": { "type": "string", "description": "UUID do blueprint" },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 50
    },
    "name": { "type": "string", "maxLength": 100 },
    "problem": { "type": "string", "description": "Problema principal" },
    "goal": { "type": "string", "description": "Objetivo prático" },
    "scope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "O que está dentro do escopo"
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "O que está explicitamente fora"
    },
    "mode": {
      "type": "string",
      "enum": ["content", "software", "research", "mixed"]
    },
    "domain": { "type": "string" },
    "locale_scope": {
      "type": "string",
      "description": "Universal or locale-specific scope for generated agent files",
      "pattern": "^(universal|[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*)$"
    },
    "locale_rationale": { "type": "string" },
    "domainClassification": {
      "type": "object",
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["tier-1-regulated", "tier-2-specialized", "tier-3-common"]
        },
        "rationale": { "type": "string" },
        "regulations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "investigationPolicy": {
          "type": "string",
          "enum": ["required", "recommended", "optional"]
        }
      }
    },
    "executors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "role"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "role": { "type": "string" },
          "focus": { "type": "array", "items": { "type": "string" } },
          "traces": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Workflows/entities (from analysis) this executor owns — derived in design Passo 2.5"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "How well the sources justify this executor's role (design decomposition)"
          },
          "modelTier": {
            "type": "string",
            "enum": ["powerful", "balanced", "fast", "none"]
          },
          "autonomyLevel": {
            "type": "string",
            "enum": ["autonomous", "semi", "approve-each"],
            "default": "semi",
            "description": "Controls how much human approval this agent requires: autonomous (runs freely), semi (pauses on key decisions), approve-each (requires approval for every action)"
          },
          "skills": { "type": "array", "items": { "type": "string" } },
          "genomes": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["slug"],
                  "properties": {
                    "slug": { "type": "string" },
                    "type": { "type": "string" },
                    "mode": { "type": "string" },
                    "source": { "type": "string" },
                    "priority": { "type": "integer" },
                    "version": { "type": "string" },
                    "evidenceMode": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "source": { "type": "string", "enum": ["local", "inherited", "catalog"] }
        }
      }
    },
    "mcps": { "type": "array", "items": { "type": "object" } },
    "genomes": { "type": "array", "items": { "type": "object" } },
    "genomeBindings": {
      "type": "object",
      "properties": {
        "squad": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["slug"],
                "properties": {
                  "slug": { "type": "string" },
                  "type": { "type": "string" },
                  "mode": { "type": "string" },
                  "source": { "type": "string" },
                  "priority": { "type": "integer" },
                  "version": { "type": "string" },
                  "evidenceMode": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            ]
          }
        },
        "executors": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["slug"],
                  "properties": {
                    "slug": { "type": "string" },
                    "type": { "type": "string" },
                    "mode": { "type": "string" },
                    "source": { "type": "string" },
                    "priority": { "type": "integer" },
                    "version": { "type": "string" },
                    "evidenceMode": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "contentBlueprints": { "type": "array", "items": { "type": "object" } },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suposições feitas durante o design"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "probability": { "type": "string", "enum": ["low", "medium", "high"] },
          "impact": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "readiness": {
      "type": "object",
      "description": "Estado de prontidão (detalhado na Fase 2)"
    },
    "analysis": {
      "type": "object",
      "description": "Domain decomposition from sourceDocs (design Passo 2.5) — the roster is derived from this",
      "properties": {
        "entities": { "type": "array", "items": { "type": "string" } },
        "workflows": { "type": "array", "items": { "type": "string" }, "description": "Units of work as verb+object" },
        "integrations": { "type": "array", "items": { "type": "string" } },
        "stakeholders": { "type": "array", "items": { "type": "string" } }
      }
    },
    "sourceDocs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "investigation": {
      "type": "object",
      "description": "Referência à investigação de domínio do @orache",
      "properties": {
        "slug": { "type": "string" },
        "path": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "dimensionsCovered": { "type": "integer", "minimum": 0, "maximum": 7 },
        "date": { "type": "string", "format": "date" }
      }
    },
    "profiling": {
      "type": "object",
      "description": "Referência ao profiling de persona via pipeline profiler",
      "properties": {
        "person": { "type": "string" },
        "genomePath": { "type": "string" },
        "genomeSlug": { "type": "string" },
        "evidenceMode": { "type": "string", "enum": ["verified", "inferred", "mixed"] },
        "profiledAt": { "type": "string", "format": "date-time" }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Score de confiança geral"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "userAdjustments": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
