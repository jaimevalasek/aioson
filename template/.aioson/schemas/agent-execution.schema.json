{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioson.dev/schemas/agent-execution-v1.json",
  "title": "AIOSON Agent Execution Manifest",
  "type": "object",
  "required": ["version", "feature", "host", "agents", "capacity_policy", "cycle_limits", "reporting"],
  "properties": {
    "version": { "const": 1 },
    "feature": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "host": { "$ref": "#/$defs/host" },
    "generated_at": { "type": "string" },
    "agents": {
      "type": "object",
      "required": ["dev", "qa", "tester", "pentester", "validator"],
      "additionalProperties": false,
      "properties": {
        "dev": { "$ref": "#/$defs/agent" },
        "qa": { "$ref": "#/$defs/agent" },
        "tester": { "$ref": "#/$defs/agent" },
        "pentester": { "$ref": "#/$defs/agent" },
        "validator": { "$ref": "#/$defs/agent" }
      }
    },
    "development_lanes": {
      "type": "object",
      "required": ["strategy", "integration_owner", "lanes"],
      "additionalProperties": false,
      "properties": {
        "strategy": { "enum": ["single", "split"] },
        "integration_owner": { "const": "dev" },
        "lanes": {
          "type": "object",
          "maxProperties": 8,
          "propertyNames": { "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "additionalProperties": { "$ref": "#/$defs/developmentLane" }
        }
      }
    },
    "capacity_policy": {
      "type": "object",
      "required": ["strategy", "max_attempts", "backoff_ms"],
      "additionalProperties": false,
      "properties": {
        "strategy": { "enum": ["pause", "retry", "wait", "fallback"] },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "backoff_ms": { "type": "integer", "minimum": 0 },
        "allow_cross_host": { "type": "boolean" }
      }
    },
    "cycle_limits": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "reporting": {
      "type": "object",
      "required": ["format", "markdown"],
      "additionalProperties": false,
      "properties": {
        "format": { "type": "string" },
        "markdown": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "host": { "enum": ["claude", "codex", "opencode", "kimi"] },
    "fallback": {
      "type": "object",
      "required": ["host", "model"],
      "additionalProperties": false,
      "properties": {
        "host": { "$ref": "#/$defs/host" },
        "model": { "type": "string", "minLength": 1, "maxLength": 200 },
        "on": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["capacity", "unavailable"] }
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "host", "mode", "model", "writable_roots", "fallbacks", "report"],
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "$ref": "#/$defs/host" },
        "mode": { "enum": ["fresh-session", "subagent", "external", "current-session"] },
        "model": { "type": "string", "minLength": 1, "maxLength": 200 },
        "reasoning_effort": { "enum": ["low", "medium", "high", "xhigh", "max", "ultra"] },
        "writable_roots": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "fallbacks": { "type": "array", "items": { "$ref": "#/$defs/fallback" } },
        "report": { "type": "string", "pattern": "\\{run_id\\}" }
      }
    },
    "developmentLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "host", "mode", "model", "writable_roots", "prompt", "write_paths", "fallbacks", "report"],
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "$ref": "#/$defs/host" },
        "mode": { "enum": ["fresh-session", "subagent", "external", "current-session"] },
        "model": { "type": "string", "minLength": 1, "maxLength": 200 },
        "reasoning_effort": { "enum": ["low", "medium", "high", "xhigh", "max", "ultra"] },
        "writable_roots": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "prompt": { "type": "string", "minLength": 1 },
        "write_paths": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "fallbacks": { "type": "array", "items": { "$ref": "#/$defs/fallback" } },
        "report": { "type": "string", "pattern": "\\{run_id\\}" }
      }
    }
  },
  "additionalProperties": false
}
