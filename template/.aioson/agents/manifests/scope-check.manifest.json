{
  "agent_id": "scope-check",
  "version": "2.0",
  "display_name": "Scope Check",
  "capabilities": [{
    "id": "review_named_scope_drift",
    "category": "verify",
    "description": "Compare PRD, plan, and delivery for one named drift concern without creating a gate.",
    "inputs": [
      { "type": "artifact", "path_pattern": ".aioson/context/prd-{slug}.md", "required": true },
      { "type": "artifact", "path_pattern": ".aioson/context/implementation-plan-{slug}.md", "required": true }
    ],
    "outputs": []
  }],
  "autonomy_modes": ["guarded", "trusted"],
  "default_mode": "guarded",
  "check_modes": ["pre-dev", "post-dev", "post-fix", "final"],
  "supported_tools": ["codex", "claude", "opencode"],
  "risk_profile": "medium"
}
