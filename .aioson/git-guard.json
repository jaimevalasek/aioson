{
  "version": 1,
  "description": "Project-specific overrides for aioson git:guard. allowPaths suppress both path-based and content-based checks for listed paths.",
  "allowPaths": [],
  "contentAllowPaths": [
    "src/i18n/**",
    "src/parser.js",
    "src/lib/git-commit-guard.js",
    "src/commands/context-health.js",
    "src/commands/context-trim.js",
    "tests/**",
    "src/commands/live.js",
    ".aioson/plans/secure-by-default/corrections-2026-04-28.md",
    ".aioson/context/security-findings-project.json"
  ],
  "blockPaths": [
    "done/**",
    "references/**",
    "node_modules/**",
    "integrations/**",
    "aioson-logs/**"
  ],
  "allowExtensions": [],
  "blockExtensions": []
}
